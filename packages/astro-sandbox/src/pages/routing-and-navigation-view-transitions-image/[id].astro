---
import ViewTransitionsLayout from '../../layouts/ViewTransitionsLayout.astro';

const images = [
  {
    id: 1,
    title: 'Sunset Mountains',
    color: '#ff6b6b',
    desc: 'Beautiful mountain sunset',
    details:
      'Captured during a hiking trip in the Rocky Mountains. The golden hour light painted the peaks in stunning warm tones.',
  },
  {
    id: 2,
    title: 'Ocean Waves',
    color: '#4ecdc4',
    desc: 'Peaceful ocean waves',
    details:
      'A serene morning at the Pacific coast. The gentle waves created a meditative atmosphere perfect for contemplation.',
  },
  {
    id: 3,
    title: 'Forest Path',
    color: '#95e77d',
    desc: 'Mystical forest trail',
    details:
      'Deep in the heart of an ancient forest, this trail winds through towering trees and dappled sunlight.',
  },
  {
    id: 4,
    title: 'Desert Dunes',
    color: '#ffd93d',
    desc: 'Golden desert landscape',
    details:
      'The Sahara Desert at sunrise. These massive dunes shift constantly with the wind, creating ever-changing patterns.',
  },
  {
    id: 5,
    title: 'Northern Lights',
    color: '#a78bfa',
    desc: 'Aurora borealis display',
    details:
      'Witnessed in Iceland during peak aurora season. The dancing lights put on a spectacular show across the night sky.',
  },
  {
    id: 6,
    title: 'Cherry Blossoms',
    color: '#fbb6ce',
    desc: 'Spring cherry trees',
    details:
      'Traditional Japanese cherry blossom season. These delicate flowers bloom for only a brief period each year.',
  },
];

const id = Astro.params.id;
const image = images.find((img) => img.id === Number(id));

if (!image) {
  return Astro.redirect('/routing-and-navigation-view-transitions-gallery');
}
---

<ViewTransitionsLayout title={`${image.title} - View Transitions`}>
  <div class="image-detail">
    <div
      class="image-hero"
      transition:name={`image-${image.id}`}
      style={`background: ${image.color}`}
      transition:animate="initial"
    >
      <div class="image-content">
        <h1 transition:name="image-title">{image.title}</h1>
        <p class="image-desc">{image.desc}</p>
      </div>
    </div>

    <div class="detail-content" transition:animate="slide">
      <div class="metadata">
        <div class="meta-item">
          <strong>Image ID:</strong> #{image.id}
        </div>
        <div class="meta-item">
          <strong>Color:</strong>
          <span class="color-swatch" style={`background: ${image.color}`}></span>
          {image.color}
        </div>
      </div>

      <div class="description-panel">
        <h2>About This Image</h2>
        <p>{image.details}</p>
      </div>

      <div class="transition-info">
        <h2>Transition Animation</h2>
        <p>
          This page uses <code>transition:name</code> to morph the gallery thumbnail into the full-size
          hero image. The title also transitions smoothly.
        </p>
        <ul>
          <li>Hero image: <code>transition:name="image-{image.id}"</code></li>
          <li>Title: <code>transition:name="image-title"</code></li>
          <li>Content: <code>transition:animate="slide"</code></li>
        </ul>
      </div>

      <div class="navigation-buttons">
        <a href="/routing-and-navigation-view-transitions-gallery" class="button">
          ← Back to Gallery
        </a>
        {
          image.id > 1 && (
            <a
              href={`/routing-and-navigation-view-transitions-image/${image.id - 1}`}
              class="button"
            >
              ← Previous
            </a>
          )
        }
        {
          image.id < images.length && (
            <a
              href={`/routing-and-navigation-view-transitions-image/${image.id + 1}`}
              class="button"
            >
              Next →
            </a>
          )
        }
      </div>
    </div>
  </div>
</ViewTransitionsLayout>

<style>
  .image-detail {
    animation: fadeIn 0.3s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .image-hero {
    width: 100%;
    aspect-ratio: 21/9;
    border-radius: 16px;
    display: flex;
    align-items: flex-end;
    margin-bottom: 2rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .image-content {
    width: 100%;
    padding: 3rem 2rem 2rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
  }

  .image-content h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .image-desc {
    font-size: 1.3rem;
    opacity: 0.9;
  }

  .detail-content {
    max-width: 800px;
  }

  .metadata {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .meta-item {
    background: rgba(102, 126, 234, 0.1);
    padding: 1rem 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(102, 126, 234, 0.3);
  }

  .color-swatch {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 4px;
    vertical-align: middle;
    border: 2px solid white;
  }

  .description-panel,
  .transition-info {
    background: rgba(30, 41, 59, 0.6);
    padding: 2rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .description-panel h2,
  .transition-info h2 {
    color: #667eea;
    margin-bottom: 1rem;
  }

  .transition-info code {
    background: rgba(0, 0, 0, 0.4);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    color: #fbbf24;
  }

  .transition-info ul {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }

  .transition-info li {
    margin: 0.5rem 0;
  }

  .navigation-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .button {
    padding: 1rem 2rem;
    background: rgba(102, 126, 234, 0.2);
    border: 2px solid #667eea;
    border-radius: 8px;
    color: white;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.2s;
  }

  .button:hover {
    background: #667eea;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .image-hero {
      aspect-ratio: 16/9;
    }

    .image-content h1 {
      font-size: 2rem;
    }

    .metadata {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
