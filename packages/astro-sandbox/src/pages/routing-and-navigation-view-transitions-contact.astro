---
import ViewTransitionsLayout from '../layouts/ViewTransitionsLayout.astro';
---

<ViewTransitionsLayout title="Contact - View Transitions">
  <div class="contact-page">
    <h1 transition:name="page-title" transition:animate="slide">📬 Contact Us</h1>

    <div class="contact-grid">
      <section class="form-section" transition:animate="slide">
        <h2>Send a Message</h2>
        <form id="contact-form">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject" required>
              <option value="">Select a subject</option>
              <option value="general">General Inquiry</option>
              <option value="support">Technical Support</option>
              <option value="feedback">Feedback</option>
              <option value="demo">Demo Request</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>

          <button type="submit" class="submit-button"> Send Message → </button>
        </form>

        <div id="form-result" class="form-result hidden"></div>
      </section>

      <aside class="info-section" transition:animate="slide">
        <div class="info-panel">
          <h2>📍 Location</h2>
          <p>123 Web Street<br />Internet City, WEB 12345<br />Digital World</p>
        </div>

        <div class="info-panel">
          <h2>📧 Email</h2>
          <p>
            <a href="mailto:hello@example.com">hello@example.com</a><br />
            <a href="mailto:support@example.com">support@example.com</a>
          </p>
        </div>

        <div class="info-panel">
          <h2>🕒 Hours</h2>
          <p>
            Monday - Friday: 9:00 AM - 6:00 PM<br />Saturday: 10:00 AM - 4:00 PM<br />Sunday: Closed
          </p>
        </div>

        <div class="info-panel">
          <h2>🌐 Social Media</h2>
          <div class="social-links">
            <a href="#" class="social-link">Twitter</a>
            <a href="#" class="social-link">GitHub</a>
            <a href="#" class="social-link">LinkedIn</a>
          </div>
        </div>
      </aside>
    </div>

    <section class="demo-note" transition:animate="fade">
      <h2>Note About This Demo</h2>
      <p>
        This contact form demonstrates View Transitions in action. Notice how the page elements
        smoothly animate in when you navigate here from other pages. The navigation bar and footer
        persist across all pages without re-mounting.
      </p>
    </section>
  </div>
</ViewTransitionsLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const result = document.getElementById('form-result') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Simulate form submission
    result.classList.remove('hidden', 'error');
    result.classList.add('success');
    result.textContent = 'Message sent successfully! (Demo only - not actually sent)';

    console.log('Form data (demo):', data);

    form.reset();

    setTimeout(() => {
      result.classList.add('hidden');
    }, 5000);
  });
</script>

<style>
  .contact-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .form-section,
  .info-section {
    background: rgba(30, 41, 59, 0.6);
    border: 1px solid rgba(102, 126, 234, 0.3);
    border-radius: 12px;
    padding: 2rem;
  }

  .form-section h2,
  .info-panel h2 {
    color: #667eea;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: #fbbf24;
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: 0.75rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    color: white;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: #667eea;
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  .submit-button {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 8px;
    color: white;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .submit-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
  }

  .form-result {
    padding: 1rem;
    border-radius: 6px;
    margin-top: 1rem;
    font-weight: 500;
  }

  .form-result.hidden {
    display: none;
  }

  .form-result.success {
    background: rgba(16, 185, 129, 0.2);
    border: 1px solid #10b981;
    color: #10b981;
  }

  .form-result.error {
    background: rgba(239, 68, 68, 0.2);
    border: 1px solid #ef4444;
    color: #ef4444;
  }

  .info-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-panel {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 8px;
  }

  .info-panel h2 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .info-panel p {
    line-height: 1.8;
  }

  .info-panel a {
    color: #667eea;
    text-decoration: none;
    transition: color 0.2s;
  }

  .info-panel a:hover {
    color: #764ba2;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-link {
    padding: 0.5rem 1rem;
    background: rgba(102, 126, 234, 0.2);
    border: 1px solid #667eea;
    border-radius: 6px;
    color: white !important;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .social-link:hover {
    background: #667eea;
    transform: translateY(-2px);
  }

  .demo-note {
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid #fbbf24;
    border-radius: 12px;
    padding: 2rem;
  }

  .demo-note h2 {
    color: #fbbf24;
    margin-bottom: 1rem;
  }

  .demo-note p {
    line-height: 1.8;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }
  }
</style>
