---
const { user } = Astro.locals;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Public Page</title>
  </head>
  <body>
    <div class="container">
      <h1>🌍 Public Page</h1>
      <p>This page is accessible to everyone, including guests.</p>

      <div class="public-panel">
        <h2>✅ No Authentication Required</h2>
        <p>Anyone can view this page.</p>
        <p>Current visitor: <strong>{user?.name}</strong> ({user?.role})</p>

        <div class="info">
          <h3>Public Content</h3>
          <p>
            This demonstrates that middleware can allow unrestricted access to certain routes while
            protecting others.
          </p>
        </div>
      </div>

      <a href="/routing-and-navigation-middleware-demo">← Back to Middleware Demo</a>
    </div>

    <style>
      body {
        font-family: system-ui, sans-serif;
        background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
        color: white;
        padding: 2rem;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .container {
        max-width: 600px;
        text-align: center;
      }

      h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
      }

      .public-panel {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: 12px;
        margin: 2rem 0;
      }

      .info {
        margin-top: 2rem;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: 8px;
      }

      .info h3 {
        margin-bottom: 0.5rem;
      }

      a {
        color: white;
        text-decoration: none;
        font-weight: bold;
        border-bottom: 2px solid white;
      }
    </style>
  </body>
</html>
