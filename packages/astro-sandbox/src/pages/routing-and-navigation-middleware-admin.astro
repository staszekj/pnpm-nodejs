---
const { user } = Astro.locals;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Page</title>
  </head>
  <body>
    <div class="container">
      <h1>👑 Admin Dashboard</h1>
      <p>This page is only accessible to administrators.</p>

      <div class="admin-panel">
        <h2>✅ Admin Access Granted</h2>
        <p>Welcome, <strong>{user?.name}</strong>!</p>
        <p>Role: <span class="role admin">{user?.role}</span></p>

        <div class="stats">
          <div class="stat">
            <h3>Total Users</h3>
            <p class="number">1,234</p>
          </div>
          <div class="stat">
            <h3>Active Sessions</h3>
            <p class="number">56</p>
          </div>
          <div class="stat">
            <h3>Requests Today</h3>
            <p class="number">8,912</p>
          </div>
        </div>
      </div>

      <a href="/routing-and-navigation-middleware-demo">← Back to Middleware Demo</a>
    </div>

    <style>
      body {
        font-family: system-ui, sans-serif;
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 2rem;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .container {
        max-width: 800px;
        text-align: center;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
      }

      .admin-panel {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: 12px;
        margin: 2rem 0;
      }

      .role.admin {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.3);
        font-weight: bold;
        font-size: 1.1rem;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
      }

      .stat {
        background: rgba(255, 255, 255, 0.2);
        padding: 1.5rem;
        border-radius: 8px;
      }

      .stat h3 {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        opacity: 0.9;
      }

      .number {
        font-size: 2rem;
        font-weight: bold;
      }

      a {
        color: white;
        text-decoration: none;
        font-weight: bold;
        border-bottom: 2px solid white;
      }
    </style>
  </body>
</html>
