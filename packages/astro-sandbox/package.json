{
  "name": "astro-sandbox",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "prettier --check \"**/*.{ts,astro,json,md}\" && astro check && eslint .",
    "lint:fix": "prettier --write \"**/*.{ts,astro,json,md}\" && astro check && eslint . --fix",
    "format": "prettier --write \"**/*.{ts,astro,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,astro,json,md}\"",
    "type-check": "astro check",
    "type-check:watch": "astro check --watch"
  },
  "dependencies": {
    "@astrojs/node": "^8.2.5",
    "astro": "^4.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.5.0",
    "@eslint/js": "^9.0.0",
    "astro-eslint-parser": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-astro": "^0.13.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
